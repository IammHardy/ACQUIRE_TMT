<% content_for :title, "Set up your buyer profile" %>
<%
  input = "mt-1 w-full rounded-sm border border-brand-100 px-4 py-2.5 text-sm text-brand-900 focus:border-brand-300 focus:outline-none focus:ring-1 focus:ring-brand-300"
  tile = "cursor-pointer rounded-sm border border-brand-100 px-4 py-3 text-center text-sm font-semibold text-brand-900 transition hover:border-brand-300 has-[:checked]:border-brand-900 has-[:checked]:bg-brand-50"
  to_m = ->(v) { v.present? ? (v.to_i / 1_000_000.0).round : nil }
%>

<section class="min-h-screen bg-brand-50 py-10">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8" data-controller="wizard">
    <div class="h-2 overflow-hidden rounded-full bg-brand-100">
      <div data-wizard-target="progress" class="h-full w-1/4 rounded-full bg-brand-900 transition-all duration-300"></div>
    </div>

    <%= form_with model: @user, url: onboarding_path, method: :patch, class: "mt-8" do |f| %>
      <% if @user.errors.any? %>
        <p class="mb-5 rounded-sm border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700"><%= @user.errors.full_messages.to_sentence %></p>
      <% end %>

      <!-- STEP 1: Buyer Type -->
      <div data-wizard-target="step" class="rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
        <h1 class="font-serif text-3xl font-medium text-brand-900">Buyer type</h1>
        <p class="mt-1 text-sm text-slate-600">Tell us how you're acquiring.</p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <% User::BUYER_TYPES.each do |type| %>
            <label class="<%= tile %>">
              <%= f.radio_button :buyer_type, type, checked: (@user.buyer_type == type || (@user.buyer_type.blank? && type == "Individual")), class: "sr-only" %>
              <%= type %>
            </label>
          <% end %>
        </div>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div>
            <%= f.label :phone, "Phone", class: "block text-sm font-semibold text-brand-900" %>
            <%= f.telephone_field :phone, class: input %>
          </div>
          <div>
            <%= f.label :occupation, "Current occupation", class: "block text-sm font-semibold text-brand-900" %>
            <%= f.text_field :occupation, class: input %>
          </div>
        </div>
      </div>

      <!-- STEP 2: Investment Criteria -->
      <div data-wizard-target="step" class="hidden rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
        <h1 class="font-serif text-3xl font-medium text-brand-900">Investment criteria</h1>
        <p class="mt-1 text-sm text-slate-600">What are you looking for in your next acquisition?</p>

        <p class="mt-6 text-sm font-semibold text-brand-900">Sectors of interest</p>
        <div class="mt-2 grid gap-2 sm:grid-cols-3">
          <% ValuationData::SECTORS.each do |slug, sector| %>
            <label class="<%= tile %>">
              <%= check_box_tag "user[mandate_industries][]", slug, @user.mandate_industries.include?(slug), class: "sr-only" %>
              <%= sector["name"] %>
            </label>
          <% end %>
        </div>

        <div class="mt-6">
          <%= f.label :additional_context, "Additional interest context", class: "block text-sm font-semibold text-brand-900" %>
          <%= f.text_area :additional_context, rows: 3, placeholder: "More detail on what you want within these sectors…", class: input %>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div>
            <p class="text-sm font-semibold text-brand-900">Enterprise value ($M)</p>
            <div class="mt-1 flex gap-3">
              <%= f.number_field :ev_min, value: to_m.call(@user.ev_min), placeholder: "Min", class: input %>
              <%= f.number_field :ev_max, value: to_m.call(@user.ev_max), placeholder: "Max", class: input %>
            </div>
          </div>
          <div>
            <p class="text-sm font-semibold text-brand-900">EBITDA ($M)</p>
            <div class="mt-1 flex gap-3">
              <%= f.number_field :ebitda_min, value: to_m.call(@user.ebitda_min), placeholder: "Min", class: input %>
              <%= f.number_field :ebitda_max, value: to_m.call(@user.ebitda_max), placeholder: "Max", class: input %>
            </div>
          </div>
        </div>

        <p class="mt-6 text-sm font-semibold text-brand-900">Geographic focus <span class="font-normal text-slate-400">(optional)</span></p>
        <div class="mt-2 grid gap-2 sm:grid-cols-3">
          <% User::GEOGRAPHIES.each do |geo| %>
            <label class="<%= tile %>">
              <%= check_box_tag "user[geographic_focus][]", geo, @user.geographic_focus.include?(geo), class: "sr-only" %>
              <%= geo %>
            </label>
          <% end %>
        </div>
      </div>

      <!-- STEP 3: Capital & Track Record -->
      <div data-wizard-target="step" class="hidden rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
        <h1 class="font-serif text-3xl font-medium text-brand-900">Capital & track record</h1>
        <p class="mt-1 text-sm text-slate-600">Tell us about your experience and funding.</p>

        <div class="mt-6">
          <%= f.label :bio, "Bio", class: "block text-sm font-semibold text-brand-900" %>
          <%= f.text_area :bio, rows: 4, placeholder: "Your background and prior professional/investing experience…", class: input %>
        </div>

        <div class="mt-6">
          <%= f.label :experience_level, "Experience level", class: "block text-sm font-semibold text-brand-900" %>
          <%= f.select :experience_level, User::EXPERIENCE_LEVELS, { include_blank: "Select an option" }, class: input %>
        </div>

        <p class="mt-6 text-sm font-semibold text-brand-900">Sources of funds</p>
        <div class="mt-2 grid gap-2 sm:grid-cols-2">
          <% User::FUNDING_SOURCES.each do |source| %>
            <label class="<%= tile %>">
              <%= check_box_tag "user[funding_sources][]", source, @user.funding_sources.include?(source), class: "sr-only" %>
              <%= source %>
            </label>
          <% end %>
        </div>

        <div class="mt-6">
          <%= f.label :personal_liquidity, "Personal liquidity", class: "block text-sm font-semibold text-brand-900" %>
          <%= f.select :personal_liquidity, User::LIQUIDITY_LEVELS, { include_blank: "Select personal liquidity" }, class: input %>
        </div>
      </div>

      <!-- STEP 4: Review & Submit -->
      <div data-wizard-target="step" class="hidden rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
        <h1 class="font-serif text-3xl font-medium text-brand-900">Review & submit</h1>
        <p class="mt-1 text-sm text-slate-600">Submit your profile for review.</p>
        <div class="mt-6 rounded-sm bg-brand-50 p-6 text-sm leading-6 text-slate-700">
          <p>By submitting, your buyer profile goes to the AcquireTMT team for review. Once approved, your curated deal feed unlocks and we'll email you when new deals match your mandate.</p>
        </div>
      </div>

      <!-- Controls -->
      <div class="mt-6 flex items-center justify-between">
        <button type="button" data-wizard-target="back" data-action="wizard#prev"
          class="invisible flex items-center gap-2 rounded-sm border border-brand-100 bg-white px-5 py-3 text-sm font-bold text-brand-900 hover:bg-white">
          <%= lucide_icon "arrow-left", class: "h-4 w-4" %> Back
        </button>
        <button type="button" data-wizard-target="next" data-action="wizard#next"
          class="flex items-center gap-2 rounded-sm bg-brand-900 px-6 py-3 text-sm font-bold text-white transition hover:bg-brand-500">
          Next <%= lucide_icon "arrow-right", class: "h-4 w-4" %>
        </button>
        <%= f.submit "Submit profile", data: { wizard_target: "submit" },
          class: "hidden cursor-pointer rounded-sm bg-brand-300 px-6 py-3 text-sm font-bold text-brand-900 transition hover:bg-brand-500 hover:text-white" %>
      </div>
    <% end %>
  </div>
</section>
