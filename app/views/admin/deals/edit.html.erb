<section class="bg-slate-50 py-10">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <%= link_to "← Back to deals", admin_deals_path, class: "text-sm font-bold text-brand-700" %>
    <h1 class="mt-4 text-3xl font-extrabold text-brand-900">Edit deal</h1>
    <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-soft">
      <%= render "form" %>
    </div>

    <!-- Data room documents -->
    <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-soft">
      <h2 class="text-xl font-extrabold text-brand-900">Data room documents</h2>
      <p class="mt-1 text-sm text-slate-500">Shown to buyers who have approved access and have signed the NDA.</p>

      <% if @deal.deal_documents.any? %>
        <div class="mt-5 divide-y divide-slate-200 border-y border-slate-200">
          <% @deal.deal_documents.order(:created_at).each do |doc| %>
            <div class="flex items-center justify-between gap-4 py-3 text-sm">
              <span class="font-semibold text-brand-900"><%= doc.title %></span>
              <span class="flex items-center gap-4">
                <% if doc.file.attached? %><%= link_to doc.file.filename, rails_blob_path(doc.file, disposition: "attachment"), class: "text-slate-500 hover:underline" %><% end %>
                <%= button_to "Remove", admin_deal_document_path(@deal, doc), method: :delete,
                  form: { class: "inline", data: { turbo_confirm: "Remove this document?" } }, class: "cursor-pointer text-red-600 hover:underline" %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= form_with url: admin_deal_documents_path(@deal), scope: :deal_document, method: :post do |f| %>
        <div class="mt-5 grid gap-4 sm:grid-cols-[1fr_auto] sm:items-end">
          <div>
            <%= f.label :title, "Document title", class: "block text-sm font-bold text-slate-700" %>
            <%= f.text_field :title, placeholder: "e.g. Confidential Information Memorandum",
              class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-brand-900" %>
          </div>
          <%= f.file_field :file, class: "text-sm" %>
        </div>
        <%= f.submit "Add document", class: "mt-4 cursor-pointer rounded-lg bg-brand-900 px-5 py-2.5 text-sm font-bold text-white hover:bg-black" %>
      <% end %>
    </div>

    <!-- Offers (shown in the seller's dashboard "Offers" tab) -->
    <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-soft">
      <h2 class="text-xl font-extrabold text-brand-900">Offers</h2>
      <p class="mt-1 text-sm text-slate-500">Buyer offers on this deal. Appear in the seller's dashboard.</p>

      <% if @deal.offers.any? %>
        <div class="mt-5 divide-y divide-slate-200 border-y border-slate-200">
          <% @deal.offers.order(created_at: :desc).each do |offer| %>
            <div class="flex items-center justify-between gap-4 py-3 text-sm">
              <span class="text-brand-900"><span class="font-semibold"><%= offer.buyer_name %></span> · <%= offer.buyer_kind %> · <%= number_to_currency(offer.purchase_price.to_i, precision: 0) %> (<%= offer.upfront_cash_pct %>% upfront)</span>
              <%= button_to "Remove", admin_deal_offer_path(@deal, offer), method: :delete,
                form: { class: "inline", data: { turbo_confirm: "Remove this offer?" } }, class: "cursor-pointer text-red-600 hover:underline" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= form_with url: admin_deal_offers_path(@deal), scope: :offer, method: :post do |f| %>
        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          <%= f.text_field :buyer_name, placeholder: "Buyer name", class: "rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
          <%= f.select :buyer_kind, ["Private Equity", "Corporate", "Individual"], { include_blank: "Buyer type" }, class: "rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
          <%= f.number_field :purchase_price, placeholder: "Purchase price ($)", class: "rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
          <%= f.number_field :upfront_cash_pct, placeholder: "Upfront %", class: "rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
          <%= f.number_field :seller_note_pct, placeholder: "Seller note %", class: "rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
          <%= f.number_field :equity_rollover_pct, placeholder: "Equity rollover %", class: "rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
        </div>
        <%= f.submit "Add offer", class: "mt-4 cursor-pointer rounded-lg bg-brand-900 px-5 py-2.5 text-sm font-bold text-white hover:bg-black" %>
      <% end %>
    </div>

    <!-- Meetings -->
    <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-soft">
      <h2 class="text-xl font-extrabold text-brand-900">Upcoming meetings</h2>
      <% if @deal.meetings.any? %>
        <div class="mt-5 divide-y divide-slate-200 border-y border-slate-200">
          <% @deal.meetings.order(:scheduled_at).each do |m| %>
            <div class="flex items-center justify-between gap-4 py-3 text-sm">
              <span class="text-brand-900"><span class="font-semibold"><%= m.buyer_name %></span><% if m.scheduled_at %> · <%= m.scheduled_at.strftime("%d %b %Y, %I:%M %p") %><% end %><% if m.note.present? %> · <%= m.note %><% end %></span>
              <%= button_to "Remove", admin_deal_meeting_path(@deal, m), method: :delete,
                form: { class: "inline", data: { turbo_confirm: "Remove this meeting?" } }, class: "cursor-pointer text-red-600 hover:underline" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= form_with url: admin_deal_meetings_path(@deal), scope: :meeting, method: :post do |f| %>
        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          <%= f.text_field :buyer_name, placeholder: "Buyer name", class: "rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
          <%= f.datetime_local_field :scheduled_at, class: "rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
          <%= f.text_field :note, placeholder: "Note (optional)", class: "rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
        </div>
        <%= f.submit "Add meeting", class: "mt-4 cursor-pointer rounded-lg bg-brand-900 px-5 py-2.5 text-sm font-bold text-white hover:bg-black" %>
      <% end %>
    </div>
  </div>
</section>
