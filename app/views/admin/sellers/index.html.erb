<% content_for :title, "Sellers — Admin" %>
<section class="py-10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-extrabold text-brand-900">Sellers</h1>
    <p class="mt-2 text-slate-600">Seller accounts. Sellers don't require approval — they sign up and use the tools right away. Assign a deal to a seller from <%= link_to "Deals", admin_deals_path, class: "font-semibold text-brand-700 hover:underline" %>.</p>

    <div class="mt-8 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-soft">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <% ["Name", "Email", "Tool runs", "Deal", "Joined"].each do |h| %>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase text-slate-500"><%= h %></th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            <% if @sellers.any? %>
              <% @sellers.each do |seller| %>
                <tr>
                  <td class="px-6 py-4 text-sm font-semibold text-brand-900"><%= seller.display_name %></td>
                  <td class="px-6 py-4 text-sm text-slate-600"><%= seller.email_address %></td>
                  <td class="px-6 py-4 text-sm text-slate-600"><%= seller.tool_runs.count %></td>
                  <td class="px-6 py-4 text-sm text-slate-600"><%= Deal.find_by(seller: seller)&.project_label || "—" %></td>
                  <td class="px-6 py-4 text-sm text-slate-600"><%= seller.created_at.strftime("%d %b %Y") %></td>
                </tr>
              <% end %>
            <% else %>
              <tr><td colspan="5" class="px-6 py-10 text-center text-sm text-slate-400">No seller accounts yet.</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
