<% content_for :title, "Insights — AcquireTMT" %>

<section class="bg-brand-900 text-white">
  <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8 lg:py-28">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">Insights</p>
    <h1 class="mt-5 max-w-4xl font-serif text-5xl font-medium leading-[1.05] tracking-tight text-white sm:text-6xl">
      Perspectives on
      <span class="text-brand-300">selling a TMT business.</span>
    </h1>
    <p class="mt-6 max-w-2xl text-xl text-white/80">
      Practical guidance on valuation, buyer demand, deal structure, and exit readiness for technology-enabled founders.
    </p>
  </div>
</section>

<section class="bg-brand-50 py-24 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-3">
      <% [
        ["Valuation", "What is your TMT business really worth?", "How recurring revenue, margin, growth, and customer concentration shape the multiple buyers will pay."],
        ["Buyers", "Strategic vs. financial buyers: who pays more?", "Understanding the trade-offs between strategic acquirers, PE platforms, and search funds."],
        ["Process", "Running a confidential sale process", "How to explore a sale without tipping off competitors, customers, or your team."],
        ["Readiness", "Diligence-ready before you launch", "The financial, legal, and operational prep that protects your valuation in diligence."],
        ["Market", "Reading TMT deal comps", "How to benchmark your business against recent transactions in your sector."],
        ["Structure", "Earnouts, escrows, and deal terms", "Why headline price isn't everything — and what terms actually move net proceeds."]
      ].each_with_index do |(tag, title, excerpt), i| %>
        <article class="flex flex-col rounded-sm border border-brand-100 bg-white p-8 shadow-soft hover-lift">
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-300"><%= tag %></span>
          <h2 class="mt-4 font-serif text-2xl font-medium leading-snug text-brand-900"><%= title %></h2>
          <p class="mt-3 flex-1 text-sm leading-7 text-slate-600"><%= excerpt %></p>
          <span class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-slate-400">
            Coming soon
          </span>
        </article>
      <% end %>
    </div>
  </div>
</section>

<section class="bg-white py-24 sm:py-28">
  <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="font-serif text-4xl font-medium leading-tight text-brand-900 sm:text-5xl">
      Have a question about your exit?
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600">
      Speak with an advisor or run a free valuation snapshot to get specific answers for your business.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <%= link_to "Get a Valuation", tools_valuation_path,
        class: "rounded-sm bg-brand-900 px-6 py-3 text-base font-bold text-white hover:bg-black" %>
      <%= link_to "Speak With an Advisor", contact_path,
        class: "rounded-sm border border-slate-300 px-6 py-3 text-base font-bold text-brand-900 hover:bg-brand-50" %>
    </div>
  </div>
</section>
