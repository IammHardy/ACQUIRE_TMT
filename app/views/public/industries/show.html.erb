<% content_for :title, "#{@industry[:name]} M&A Advisory — AcquireTMT" %>

<section class="bg-brand-900 text-white">
  <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8 lg:py-28">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">
      Industry advisory
    </p>

    <h1 class="mt-5 max-w-4xl font-serif text-5xl font-medium leading-[1.05] tracking-tight text-white sm:text-6xl">
      M&A advisory for
      <span class="text-brand-300"><%= @industry[:name] %></span>
      businesses.
    </h1>

    <p class="mt-6 max-w-2xl text-xl text-white/80"><%= @industry[:tagline] %></p>

    <div class="mt-8 max-w-xl">
      <%= form_with url: tools_find_buyers_path, method: :get do %>
        <div class="flex flex-col overflow-hidden rounded-sm bg-white shadow-xl md:flex-row">
          <input
            type="url"
            name="company_website"
            placeholder="Enter your company website"
            class="flex-1 border-0 px-5 py-4 text-base text-black outline-none focus:ring-0">
          <button
            type="submit"
            class="bg-brand-300 px-6 py-4 text-base font-bold text-black hover:bg-white">
            Find Buyers
          </button>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="bg-brand-50 py-24 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-serif text-4xl font-medium leading-tight text-brand-900 sm:text-5xl">
        How buyers value <%= @industry[:name] %> companies
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-slate-600">
        <%= @industry[:intro] %>
      </p>
    </div>

    <div class="mt-16 grid gap-8 lg:grid-cols-2">
      <div class="rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
        <h3 class="font-serif text-3xl font-medium text-brand-900">Key value drivers</h3>
        <ul class="mt-6 space-y-4">
          <% @industry[:value_drivers].each do |driver| %>
            <li class="flex gap-3">
              <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-300 text-brand-900">
                <%= lucide_icon "check", class: "h-4 w-4" %>
              </span>
              <span class="text-base leading-7 text-slate-700"><%= driver %></span>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="rounded-sm border border-brand-100 bg-brand-900 p-8 text-white shadow-soft">
        <h3 class="font-serif text-3xl font-medium text-white">Likely buyers</h3>
        <ul class="mt-6 space-y-4">
          <% @industry[:buyers].each do |buyer| %>
            <li class="flex gap-3">
              <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-300 text-brand-900">
                <%= lucide_icon "users", class: "h-4 w-4" %>
              </span>
              <span class="text-base leading-7 text-white/80"><%= buyer %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="bg-white py-24 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">Get started</p>
      <h2 class="mt-5 font-serif text-4xl font-medium leading-tight text-brand-900 sm:text-5xl">
        Explore your <%= @industry[:name] %> exit
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-slate-600">
        Start with a free valuation snapshot, market comps, or a preliminary buyer universe for your business.
      </p>
    </div>

    <div class="mx-auto mt-12 grid max-w-5xl gap-6 sm:grid-cols-3">
      <% [
        ["Valuation Snapshot", "Benchmark your value range.", tools_valuation_path],
        ["Market Comps", "Compare to similar businesses.", tools_market_comps_path],
        ["Find Buyers", "See your buyer universe.", tools_find_buyers_path]
      ].each do |title, desc, path| %>
        <%= link_to path, class: "group rounded-sm border border-brand-100 bg-brand-50 p-8 transition hover:bg-brand-900" do %>
          <h3 class="font-serif text-2xl font-medium text-brand-900 group-hover:text-white"><%= title %></h3>
          <p class="mt-3 text-sm leading-6 text-slate-600 group-hover:text-white/70"><%= desc %></p>
          <div class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-brand-900 group-hover:text-brand-300">
            Start
            <%= lucide_icon "chevron-right", class: "h-4 w-4 transition group-hover:translate-x-1" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
