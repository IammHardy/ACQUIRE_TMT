<div data-controller="cookie-consent"
  class="hidden fixed inset-x-0 bottom-0 z-50 border-t border-brand-100 bg-white/95 px-4 py-4 shadow-soft backdrop-blur sm:px-6 lg:px-8">
  <div class="mx-auto flex max-w-7xl flex-col items-start gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm leading-6 text-slate-600">
      We use cookies to operate this site and improve your experience. See our
      <%= link_to "Privacy Policy", privacy_path, class: "font-semibold text-brand-500 hover:underline" %>.
    </p>
    <button type="button" data-action="cookie-consent#accept"
      class="shrink-0 rounded-sm bg-brand-900 px-5 py-2 text-sm font-bold text-white transition hover:bg-brand-500">
      Accept
    </button>
  </div>
</div>
