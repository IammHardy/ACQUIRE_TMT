<div class="rounded-sm border border-brand-100 bg-white p-6 shadow-soft">
  <div class="flex items-start justify-between gap-4">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400"><%= deal.project_label %></p>
    <%= link_to "Learn more", deal_path(deal),
      class: "shrink-0 rounded-sm bg-brand-50 px-3 py-1.5 text-xs font-bold text-brand-500 transition hover:bg-brand-100" %>
  </div>

  <h3 class="mt-3 font-serif text-2xl font-medium text-brand-900"><%= deal.title %></h3>
  <p class="mt-1 text-sm leading-6 text-slate-600"><%= deal.teaser %></p>

  <div class="mt-6 grid grid-cols-2 gap-4">
    <div class="rounded-sm bg-brand-50 p-4 text-center">
      <p class="font-serif text-2xl font-medium text-brand-900"><%= number_to_currency(deal.revenue, precision: 0) %></p>
      <p class="mt-1 text-xs text-slate-500">Revenue</p>
    </div>
    <div class="rounded-sm bg-brand-50 p-4 text-center">
      <p class="font-serif text-2xl font-medium text-brand-900"><%= number_to_currency(deal.ebitda, precision: 0) %></p>
      <p class="mt-1 text-xs text-slate-500">Avg EBITDA</p>
    </div>
  </div>
</div>
