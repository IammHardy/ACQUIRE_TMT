<% content_for :title, "Your Deals" %>
<%
  status_styles = {
    "requested" => ["In review", "bg-amber-50 text-amber-700"],
    "approved"  => ["Data room open", "bg-emerald-50 text-emerald-700"],
    "declined"  => ["Declined", "bg-slate-100 text-slate-500"]
  }
%>

<section class="px-4 py-10 sm:px-6 lg:px-12">
  <div class="mx-auto max-w-5xl">
    <h1 class="font-serif text-5xl font-medium text-brand-900">Your Deals</h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">
      Track the status of all opportunities you are engaged with, from initial interest to closed transactions.
    </p>

    <% if @accesses.any? %>
      <div class="mt-10 space-y-4">
        <% @accesses.each do |access| %>
          <% deal = access.deal %>
          <% label, classes = status_styles[access.status] || [access.status.capitalize, "bg-slate-100 text-slate-500"] %>
          <%= link_to deal_path(deal), class: "flex items-center justify-between gap-4 rounded-sm border border-brand-100 bg-white p-6 shadow-soft transition hover:-translate-y-0.5" do %>
            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400"><%= deal.project_label %></p>
              <h3 class="mt-1 font-serif text-2xl font-medium text-brand-900"><%= deal.title %></h3>
              <p class="mt-1 text-sm text-slate-500"><%= deal.industry_name %> · <%= number_to_currency(deal.revenue, precision: 0) %> revenue</p>
            </div>
            <span class="shrink-0 rounded-full px-3 py-1 text-xs font-semibold <%= classes %>"><%= label %></span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="mt-28 text-center text-lg text-slate-400">No active deals</p>
    <% end %>
  </div>
</section>
