<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin — AcquireTMT" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-slate-100">
    <header class="border-b border-white/10 bg-brand-900 text-white">
      <div class="mx-auto flex max-w-7xl flex-wrap items-center gap-x-6 gap-y-2 px-4 py-3 sm:px-6 lg:px-8">
        <%= link_to root_path, class: "font-serif text-xl font-semibold" do %>Acquire<span class="text-brand-300">TMT</span><% end %>
        <span class="rounded-sm bg-white/10 px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-brand-300">Admin</span>
        <nav class="flex flex-wrap items-center gap-1 text-sm font-semibold">
          <% [["Leads", admin_leads_path], ["Deals", admin_deals_path], ["Buyers", admin_buyers_path], ["Acquirers", admin_acquirers_path], ["Access requests", admin_deal_accesses_path]].each do |label, path| %>
            <%= link_to label, path, class: "rounded-sm px-3 py-1.5 transition #{request.path.start_with?(path) ? "bg-white/15 text-white" : "text-white/70 hover:bg-white/10 hover:text-white"}" %>
          <% end %>
        </nav>
        <%= button_to "Sign out", admin_logout_path, method: :delete, class: "ml-auto cursor-pointer rounded-sm border border-white/20 px-3 py-1.5 text-sm font-bold text-white/80 transition hover:bg-white/10" %>
      </div>
    </header>

    <% if notice.present? %>
      <div class="mx-auto max-w-7xl px-4 pt-4 sm:px-6 lg:px-8"><p class="rounded-sm border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700"><%= notice %></p></div>
    <% end %>
    <% if alert.present? %>
      <div class="mx-auto max-w-7xl px-4 pt-4 sm:px-6 lg:px-8"><p class="rounded-sm border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700"><%= alert %></p></div>
    <% end %>

    <main><%= yield %></main>
  </body>
</html>
