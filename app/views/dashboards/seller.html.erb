<% content_for :title, "Dashboard" %>

<section class="min-h-screen bg-brand-50 py-12">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">Seller dashboard</p>
        <h1 class="mt-2 font-serif text-4xl font-medium text-brand-900">Welcome, <%= @user.display_name %></h1>
      </div>
    </div>

    <!-- Advisor status -->
    <div class="mt-8 rounded-sm border border-brand-100 bg-white p-6 shadow-soft">
      <% if @advisor_lead %>
        <% stages = Lead.statuses.keys %>
        <% current_index = stages.index(@advisor_lead.status) || 0 %>
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">Advisor</p>
            <p class="mt-1 font-serif text-2xl font-medium text-brand-900"><%= @advisor_lead.status_label %></p>
          </div>
          <div class="flex items-center gap-2">
            <% stages.each_with_index do |_stage, i| %>
              <span class="h-2 w-10 rounded-full <%= i <= current_index ? "bg-brand-300" : "bg-slate-200" %>"></span>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">Advisor</p>
            <p class="mt-1 text-sm text-slate-600">Ready to sell? Talk to an AcquireTMT advisor about your business.</p>
          </div>
          <%= link_to "Talk to an advisor", contact_path,
            class: "w-fit rounded-sm bg-brand-900 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-brand-500" %>
        </div>
      <% end %>
    </div>

    <!-- Deal activity (only when this seller has a live listing) -->
    <% if @seller_deal %>
      <% offers = @seller_deal.offers.order(created_at: :desc) %>
      <% meetings = @seller_deal.meetings.upcoming %>
      <% nda_requests = @seller_deal.deal_accesses.where(status: "requested").includes(:user) %>
      <div class="mt-8 rounded-sm border border-brand-100 bg-white p-8 shadow-soft" data-controller="tabs">
        <h2 class="font-serif text-2xl font-medium text-brand-900">Your deal · <%= @seller_deal.project_label %></h2>
        <p class="mt-1 text-sm text-slate-600">Track everything happening on your sale, from first interest to closed offers.</p>

        <div class="mt-6 flex flex-wrap gap-2">
          <% [["Offers", offers.size], ["Upcoming Meetings", meetings.size], ["NDA Requests", nda_requests.size]].each_with_index do |(label, count), i| %>
            <button type="button" data-action="tabs#show" data-tabs-index="<%= i %>" data-tabs-target="tab"
              class="flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold transition <%= i.zero? ? "bg-brand-900 text-white" : "bg-brand-50 text-brand-900" %>">
              <%= label %>
              <span class="rounded-full bg-black/10 px-2 py-0.5 text-xs"><%= count %></span>
            </button>
          <% end %>
        </div>

        <!-- Offers -->
        <div data-tabs-target="panel" data-index="0" class="mt-6">
          <% if offers.any? %>
            <div class="grid gap-4 sm:grid-cols-2">
              <% offers.each do |offer| %>
                <div class="rounded-sm border border-brand-100 bg-brand-50 p-5">
                  <p class="font-serif text-xl font-medium text-brand-900"><%= offer.buyer_name %></p>
                  <p class="text-xs font-semibold uppercase tracking-wide text-brand-500"><%= offer.buyer_kind %></p>
                  <div class="mt-4 space-y-2 border-t border-brand-100 pt-4 text-sm">
                    <div class="flex items-center justify-between">
                      <span class="text-slate-500">Purchase price</span>
                      <span class="font-bold text-brand-900"><%= number_to_currency(offer.purchase_price.to_i, precision: 0) %></span>
                    </div>
                    <% offer.structure_label.each do |label, value| %>
                      <div class="flex items-center justify-between">
                        <span class="text-slate-500"><%= label %></span>
                        <span class="font-bold text-brand-900"><%= value %></span>
                      </div>
                    <% end %>
                  </div>
                  <button type="button" class="mt-4 w-full rounded-sm bg-brand-900 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-brand-500">Review offer</button>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-slate-400">No offers yet — they'll appear here as buyers submit them.</p>
          <% end %>
        </div>

        <!-- Upcoming meetings -->
        <div data-tabs-target="panel" data-index="1" class="mt-6 hidden">
          <% if meetings.any? %>
            <div class="divide-y divide-brand-100 border-t border-brand-100">
              <% meetings.each do |meeting| %>
                <div class="flex items-center justify-between gap-4 py-4">
                  <div>
                    <p class="font-semibold text-brand-900"><%= meeting.buyer_name %></p>
                    <% if meeting.note.present? %><p class="text-sm text-slate-500"><%= meeting.note %></p><% end %>
                  </div>
                  <span class="text-sm text-slate-500"><%= meeting.scheduled_at ? meeting.scheduled_at.strftime("%d %b %Y, %I:%M %p") : "To be scheduled" %></span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-slate-400">No upcoming meetings.</p>
          <% end %>
        </div>

        <!-- NDA requests -->
        <div data-tabs-target="panel" data-index="2" class="mt-6 hidden">
          <% if nda_requests.any? %>
            <div class="divide-y divide-brand-100 border-t border-brand-100">
              <% nda_requests.each do |req| %>
                <div class="flex items-center justify-between gap-4 py-4">
                  <p class="font-semibold text-brand-900"><%= req.user&.display_name || "Buyer" %></p>
                  <span class="text-sm text-slate-500">Requested <%= req.created_at.strftime("%d %b %Y") %></span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-slate-400">No NDA requests yet.</p>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="mt-8 grid gap-6 lg:grid-cols-3">
      <% [
        ["Business Valuation", "Get an instant TMT valuation range.", tools_valuation_path, "trending-up"],
        ["Market Comps", "See comparable deal multiples.", tools_market_comps_path, "chart-column"],
        ["BuyerMap", "Map the buyers for your business.", tools_find_buyers_path, "target"]
      ].each do |title, desc, path, icon| %>
        <%= link_to path, class: "group rounded-sm border border-brand-100 bg-white p-6 shadow-soft transition hover:-translate-y-0.5" do %>
          <span class="flex h-10 w-10 items-center justify-center rounded-sm bg-brand-50 text-brand-500">
            <%= lucide_icon icon, class: "h-5 w-5" %>
          </span>
          <p class="mt-4 font-serif text-2xl font-medium text-brand-900"><%= title %></p>
          <p class="mt-1 text-sm text-slate-600"><%= desc %></p>
        <% end %>
      <% end %>
    </div>

    <!-- Potential buyers -->
    <div class="mt-8 rounded-sm border border-brand-100 bg-white p-8 shadow-soft" data-controller="buyer-filter">
      <h2 class="font-serif text-2xl font-medium text-brand-900">Potential buyers</h2>
      <% if @potential_buyers.any? %>
        <p class="mt-1 text-sm text-slate-600">Acquirers actively buying <%= ValuationData.sector(@sector)["name"] %> businesses like yours.</p>

        <div class="mt-5 flex flex-wrap gap-2">
          <% [["All", "all"], ["Private Equity", "Private Equity"], ["Corporate", "Corporate"], ["Individual", "Individual"]].each_with_index do |(label, cat), i| %>
            <button type="button" data-action="buyer-filter#filter" data-category="<%= cat %>" data-buyer-filter-target="tab"
              class="rounded-full px-4 py-1.5 text-sm font-semibold transition <%= i.zero? ? "bg-brand-900 text-white" : "bg-brand-50 text-brand-900" %>">
              <%= label %><%= " (#{@potential_buyers.size})" if i.zero? %>
            </button>
          <% end %>
        </div>

        <div class="mt-6 divide-y divide-brand-100 border-t border-brand-100">
          <% @potential_buyers.each do |buyer| %>
            <div data-buyer-filter-target="row" data-category="<%= buyer.category %>" class="grid gap-4 py-5 md:grid-cols-[210px_1fr_1fr]">
              <div>
                <p class="font-serif text-lg font-medium text-brand-900"><%= buyer.name %></p>
                <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-brand-500"><%= buyer.category %></p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">About</p>
                <p class="mt-1 text-sm leading-6 text-slate-600"><%= buyer.thesis %></p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Activity</p>
                <p class="mt-1 text-sm leading-6 text-slate-600">
                  <%= buyer.acquisitions_count.positive? ? "#{buyer.acquisitions_count} acquisitions in 2025" : "Active acquirer" %><% if buyer.backed_by.present? %> · Backed by <%= buyer.backed_by %><% end %>
                </p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-3 text-sm text-slate-600">
          Run the <%= link_to "BuyerMap tool", tools_find_buyers_path, class: "font-semibold text-brand-500 hover:underline" %>
          and we'll show the acquirers matched to your business here.
        </p>
      <% end %>
    </div>

    <div class="mt-8 rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
      <h2 class="font-serif text-2xl font-medium text-brand-900">Your tool history</h2>
      <p class="mt-1 text-sm text-slate-600">Valuations, comps and BuyerMaps you've run, newest first.</p>

      <% if @tool_runs.present? %>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <%= render partial: "tool_runs/run", collection: @tool_runs, as: :run %>
        </div>
      <% else %>
        <p class="mt-6 text-sm text-slate-400">No runs yet — start with a valuation above.</p>
      <% end %>
    </div>
  </div>
</section>
