<% content_for :title, "Buyer dashboard" %>

<section class="min-h-screen bg-brand-50 py-12">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="font-serif text-4xl font-medium text-brand-900">Welcome, <%= @user.display_name %></h1>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
          Here are our current and upcoming sell-side mandates. Select one to learn more and view next steps.
        </p>
      </div>
      <%= link_to "Edit mandate", onboarding_path, class: "text-sm font-semibold text-brand-700 hover:underline" %>
    </div>

    <% if @user.approved? %>
      <!-- Approved: full deal feed -->
      <div class="mt-8 flex items-end justify-between">
        <h2 class="font-serif text-3xl font-medium text-brand-900">Your deal feed</h2>
        <p class="text-sm text-slate-500"><%= pluralize(@deals.size, "deal") %></p>
      </div>
      <p class="mt-1 text-sm text-slate-500">We'll email you the moment a new deal matches your mandate.</p>

      <% if @deals.any? %>
        <div class="mt-6 grid gap-5 lg:grid-cols-2">
          <%= render partial: "deals/card", collection: @deals, as: :deal %>
        </div>
      <% else %>
        <p class="mt-6 rounded-sm border border-brand-100 bg-white px-5 py-8 text-center text-sm text-slate-400">
          No active deals match your mandate yet — we'll alert you when one does.
        </p>
      <% end %>
    <% else %>
      <!-- Pending review: blurred feed behind an "Application received" notice -->
      <div class="relative mt-8">
        <div class="pointer-events-none select-none blur-sm">
          <div class="grid gap-5 lg:grid-cols-2">
            <%= render partial: "deals/card", collection: Deal.active.order(created_at: :desc).limit(4), as: :deal %>
          </div>
        </div>

        <div class="absolute inset-0 flex items-start justify-center px-4 pt-12">
          <div class="w-full max-w-lg rounded-sm border border-brand-100 bg-white p-8 text-center shadow-soft">
            <%= lucide_icon "clock", class: "mx-auto h-7 w-7 text-brand-500" %>
            <h3 class="mt-4 font-serif text-3xl font-medium text-brand-900">
              <%= @user.approval_status == "declined" ? "Application not approved" : "Application received" %>
            </h3>
            <% if @user.approval_status == "declined" %>
              <p class="mt-3 text-sm leading-6 text-slate-600">Your buyer profile wasn't approved for the network at this time.</p>
            <% else %>
              <p class="mt-3 text-sm leading-6 text-slate-600">
                Your account has been created and is pending review by the AcquireTMT team.
                We'll notify you via email as soon as your account has been approved.
              </p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>
